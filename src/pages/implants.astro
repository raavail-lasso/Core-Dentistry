---
import GlobalLayout from '../layouts/GlobalLayout.astro';
import CTAGroup from '../components/CTAGroup.astro';
import ContactForm from '../components/ContactForm.astro';
---

<GlobalLayout title="Dental Implants Fort Mill | Permanent Tooth Replacement | Core Dentistry" description="Restore your smile with dental implants in Fort Mill, SC. Permanent, natural-looking tooth replacement at Core Dentistry. Schedule your consultation today.">


    <!-- ══════════════════════════════════════════════
         SECTION 1 — HERO (The Problem)
    ══════════════════════════════════════════════ -->
    <section class="relative min-h-screen flex items-center overflow-hidden bg-navy-dark">

      <!-- Dot grid pattern -->
      <div
        class="absolute inset-0 opacity-[0.05]"
        style="background-image: radial-gradient(circle, #d0d3da 1px, transparent 1px); background-size: 32px 32px;"
        aria-hidden="true"
      ></div>

      <!-- Soft blush glow, top right -->
      <div
        class="absolute top-0 right-0 w-2/3 h-2/3 pointer-events-none"
        style="background: radial-gradient(ellipse at top right, rgba(183, 110, 121, 0.22) 0%, transparent 65%);"
        aria-hidden="true"
      ></div>

      <!-- Content -->
      <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20 items-center">

          <!-- Left: copy + CTAs -->
          <div>
            <!-- Eyebrow label -->
            <div class="flex items-center gap-3 mb-8">
              <div class="h-px w-10 bg-rose shrink-0"></div>
              <span class="font-body text-rose text-xs font-semibold tracking-[0.2em] uppercase">
                Dental Implants — Fort Mill
              </span>
            </div>

            <h1 class="font-heading text-6xl md:text-7xl text-white leading-tight mb-8">
              Missing Teeth? Stop<br />
              Hiding Your Smile<br />
              <em class="not-italic text-rose">and Start Living Again.</em>
            </h1>

            <!-- Divider accent -->
            <div class="w-16 h-px bg-rose mb-8"></div>

            <p class="font-body text-lg text-navy-lighter leading-relaxed mb-10 max-w-xl">
              Missing teeth or loose dentures do more than just affect your appearance. They make
              it hard to eat the foods you love and can cause you to pull back from social
              situations. You deserve a permanent solution that looks, feels, and functions just
              like your natural teeth. At Core Dentistry, we help you reclaim your confidence
              with modern dental implants.
            </p>

            <CTAGroup variant="on-dark" />
          </div>

          <!-- Right: placeholder image -->
          <div class="relative hidden lg:block">
            <div class="w-full aspect-4/5 rounded-3xl overflow-hidden">
              <img src="/images/Implants.webp" alt="Dental implants Fort Mill" class="w-full h-full object-cover" />
            </div>
            <!-- Floating confidence badge -->
            <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl px-6 py-4 shadow-lg border border-cream-light">
              <p class="font-heading text-2xl text-navy leading-none mb-0.5">Lifetime</p>
              <p class="font-body text-sm text-neutral">Results Designed to Last</p>
            </div>
          </div>

        </div>
      </div>

    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 2 — AGITATION (The Hidden Risks)
    ══════════════════════════════════════════════ -->
    <section class="bg-cream-lighter py-24 md:py-32">
      <div class="max-w-7xl mx-auto px-6 md:px-10">

        <!-- Section label + heading + body -->
        <div class="max-w-2xl mb-14">
          <div class="flex items-center gap-3 mb-5">
            <div class="h-px w-8 bg-rose shrink-0"></div>
            <span class="font-body text-rose-dark text-xs font-semibold tracking-[0.2em] uppercase">The Hidden Risks</span>
          </div>
          <h2 class="font-heading text-5xl text-navy leading-snug mb-5">
            The Cost of Waiting is More Than<br />Just a Gap in Your Smile.
          </h2>
          <p class="font-body text-md text-neutral leading-relaxed">
            When a tooth is lost, the underlying jawbone begins to shrink from a lack of
            stimulation. This can lead to a collapsed facial appearance and premature aging.
            Furthermore, your remaining teeth will begin to shift into the empty space, causing
            bite misalignment and further tooth loss. Choosing to wait does not just delay the
            fix; it can make future restoration more difficult and expensive.
          </p>
        </div>

        <!-- Three consequence cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-14">

          <!-- Card 1: Bone Loss -->
          <div class="bg-white rounded-2xl p-8 border border-cream-light shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col gap-5">
            <div class="w-11 h-11 rounded-xl bg-rose-light flex items-center justify-center shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="#b76e79" stroke-width="1.75" stroke-linejoin="round"/>
                <line x1="12" y1="9" x2="12" y2="13" stroke="#b76e79" stroke-width="1.75" stroke-linecap="round"/>
                <circle cx="12" cy="17" r="0.75" fill="#b76e79"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-heading text-2xl text-navy mb-2 leading-snug">Jawbone Shrinks Over Time</h3>
              <p class="font-body text-base text-neutral leading-relaxed">
                Without a tooth root to stimulate it, the jawbone begins to deteriorate. This
                bone loss changes the shape of your face and can make future implant placement
                more complex.
              </p>
            </div>
            <div class="pt-4 border-t border-cream-light">
              <p class="font-body text-sm text-rose-dark font-semibold">Bone loss begins quickly</p>
            </div>
          </div>

          <!-- Card 2: Teeth Shift -->
          <div class="bg-white rounded-2xl p-8 border border-cream-light shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col gap-5">
            <div class="w-11 h-11 rounded-xl bg-rose-light flex items-center justify-center shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 22C12 22 4 16 4 9a8 8 0 0116 0c0 7-8 13-8 13z" stroke="#b76e79" stroke-width="1.75" stroke-linejoin="round"/>
                <circle cx="12" cy="9" r="2.5" stroke="#b76e79" stroke-width="1.75"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-heading text-2xl text-navy mb-2 leading-snug">Remaining Teeth Shift</h3>
              <p class="font-body text-base text-neutral leading-relaxed">
                Neighboring teeth drift into the empty space over time, causing bite
                misalignment, increased wear, and a higher risk of losing additional teeth.
              </p>
            </div>
            <div class="pt-4 border-t border-cream-light">
              <p class="font-body text-sm text-rose-dark font-semibold">One gap leads to more</p>
            </div>
          </div>

          <!-- Card 3: Escalating Cost -->
          <div class="bg-white rounded-2xl p-8 border border-cream-light shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col gap-5">
            <div class="w-11 h-11 rounded-xl bg-rose-light flex items-center justify-center shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="3,17 8,11 12,14 17,7" stroke="#b76e79" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="17,7 21,7 21,11" stroke="#b76e79" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="3" y1="20" x2="21" y2="20" stroke="#b76e79" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-heading text-2xl text-navy mb-2 leading-snug">Restoration Gets Costlier</h3>
              <p class="font-body text-base text-neutral leading-relaxed">
                Waiting makes future restoration more difficult and expensive. Bone grafting
                and additional procedures may be required if you delay treatment too long.
              </p>
            </div>
            <div class="pt-4 border-t border-cream-light">
              <p class="font-body text-sm text-rose-dark font-semibold">Act sooner to save more</p>
            </div>
          </div>

        </div>

        <CTAGroup />

      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 3 — SOLUTION (The "Core" Advantage)
    ══════════════════════════════════════════════ -->
    <section class="bg-white py-24 md:py-32 relative overflow-hidden">

      <!-- Decorative soft blush shape, right side -->
      <div
        class="absolute -right-48 top-1/2 -translate-y-1/2 w-[560px] h-[560px] rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(246, 238, 239, 0.85) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 xl:gap-24 items-center">

          <!-- Left: copy + CTAs -->
          <div>
            <div class="flex items-center gap-3 mb-5">
              <div class="h-px w-8 bg-rose shrink-0"></div>
              <span class="font-body text-rose-dark text-xs font-semibold tracking-[0.2em] uppercase">The Core Advantage</span>
            </div>
            <h2 class="font-heading text-5xl text-navy leading-snug mb-6">
              Permanent, Natural-Looking<br />Results Under One Roof.
            </h2>
            <p class="font-body text-md text-neutral leading-relaxed mb-4">
              Many dental offices have to refer you to an outside specialist for the surgical
              phase of an implant. At Core Dentistry, Dr. Elizabeth Alexander and Dr. Erika
              Burley provide comprehensive implant care in one convenient Fort Mill location.
            </p>
            <p class="font-heading text-2xl text-navy mb-6 leading-snug">
              "Using advanced 3D imaging and precision<br />technology, we ensure your implant is<br />placed perfectly for maximum comfort<br />and longevity."
            </p>
            <CTAGroup />
          </div>

          <!-- Right: feature highlight tiles -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

            <div class="flex items-start gap-4 p-6 bg-cream-lighter rounded-2xl border border-cream-light">
              <div class="w-10 h-10 rounded-xl bg-navy flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                  <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-xl text-navy mb-1 leading-snug">All Under One Roof</h3>
                <p class="font-body text-sm text-neutral leading-relaxed">No specialist referrals. We handle every phase of your implant from start to finish.</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-6 bg-cream-lighter rounded-2xl border border-cream-light">
              <div class="w-10 h-10 rounded-xl bg-navy flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="11" cy="11" r="7"/>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-xl text-navy mb-1 leading-snug">Advanced 3D Imaging</h3>
                <p class="font-body text-sm text-neutral leading-relaxed">Precision technology maps your jaw for ideal implant placement and lasting results.</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-6 bg-cream-lighter rounded-2xl border border-cream-light">
              <div class="w-10 h-10 rounded-xl bg-navy flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                  <path d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-xl text-navy mb-1 leading-snug">Expert Implant Team</h3>
                <p class="font-body text-sm text-neutral leading-relaxed">Dr. Alexander and Dr. Burley bring specialized experience to every implant procedure.</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-6 bg-cream-lighter rounded-2xl border border-cream-light">
              <div class="w-10 h-10 rounded-xl bg-navy flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-xl text-navy mb-1 leading-snug">Built for Longevity</h3>
                <p class="font-body text-sm text-neutral leading-relaxed">With proper care, your implant is designed to last a lifetime — a true permanent solution.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 4 — PROOF (Transformational Testimonial)
    ══════════════════════════════════════════════ -->
    <section class="relative bg-navy py-24 md:py-32 overflow-hidden">

      <!-- Subtle dot grid -->
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 36px 36px;"
        aria-hidden="true"
      ></div>

      <!-- Decorative oversized opening quotation mark -->
      <div
        class="absolute -top-6 left-4 md:left-10 font-heading leading-none pointer-events-none select-none text-rose opacity-[0.08]"
        style="font-size: clamp(160px, 22vw, 300px);"
        aria-hidden="true"
      >"</div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-10 text-center">

        <div class="flex items-center gap-3 justify-center mb-8">
          <div class="h-px w-8 bg-rose shrink-0"></div>
          <span class="font-body text-rose text-xs font-semibold tracking-[0.2em] uppercase">Real Results from Your Neighbors</span>
          <div class="h-px w-8 bg-rose shrink-0"></div>
        </div>

        <h2 class="font-heading text-5xl text-white leading-snug mb-10">
          Real Results from Your Neighbors.
        </h2>

        <!-- Five stars -->
        <div class="flex items-center justify-center gap-1.5 mb-10" role="img" aria-label="Five-star patient review">
          {[1, 2, 3, 4, 5].map((_) => (
            <svg width="26" height="26" viewBox="0 0 24 24" fill="#f5c842" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>

        <blockquote class="font-heading text-3xl md:text-4xl text-white leading-snug mb-10 italic">
          "I am so thrilled and amazed at the work Dr. Alexander does! She is very respectful,
          trustworthy and gets the job done every time. I felt absolutely no pain with my
          procedures. I almost fell asleep! I will recommend her to everyone."
        </blockquote>

        <div class="flex items-center justify-center gap-3">
          <div class="h-px w-8 bg-rose-dark shrink-0"></div>
          <cite class="font-body text-rose not-italic text-lg font-semibold">Chauntel</cite>
          <div class="h-px w-8 bg-rose-dark shrink-0"></div>
        </div>

      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 5 — FINANCIALS (Investing in Your Smile)
    ══════════════════════════════════════════════ -->
    <section class="bg-cream-lighter py-24 md:py-32">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 xl:gap-24 items-center">

          <!-- Left: copy -->
          <div>
            <div class="flex items-center gap-3 mb-5">
              <div class="h-px w-8 bg-rose shrink-0"></div>
              <span class="font-body text-rose-dark text-xs font-semibold tracking-[0.2em] uppercase">Insurance &amp; Financing</span>
            </div>
            <h2 class="font-heading text-5xl text-navy leading-snug mb-6">
              Flexible Financing for<br />a Lifetime Investment.
            </h2>
            <p class="font-body text-md text-neutral leading-relaxed mb-6">
              We understand that dental implants are a significant investment in your health
              and quality of life. Our team is dedicated to making this life-changing procedure
              affordable. We are in-network with many major providers, including Delta Dental,
              Cigna, MetLife, Guardian, and Humana.
            </p>
            <p class="font-body text-md text-neutral leading-relaxed mb-10">
              For those without insurance or for costs not covered by your plan, we offer
              flexible third-party financing and payment solutions. We handle the paperwork
              and verify your benefits so you can focus on your new smile.
            </p>
            <CTAGroup />
          </div>

          <!-- Right: insurance providers + financing callout -->
          <div class="flex flex-col gap-6">

            <!-- In-Network card -->
            <div class="bg-white rounded-2xl p-8 border border-cream-light shadow-sm">
              <h3 class="font-heading text-xl text-navy mb-5 leading-snug">Our In-Network Providers Include</h3>
              <ul class="grid grid-cols-2 gap-3">
                {['Delta Dental', 'Cigna', 'MetLife', 'Guardian', 'Humana'].map((name) => (
                  <li class="flex items-center gap-2.5 font-body text-base text-navy">
                    <span class="w-5 h-5 rounded-full bg-rose flex items-center justify-center shrink-0" aria-hidden="true">
                      <svg width="10" height="8" viewBox="0 0 10 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <polyline points="1,4.5 3.5,7 9,1" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    {name}
                  </li>
                ))}
              </ul>
            </div>

            <!-- Financing callout -->
            <div class="bg-navy rounded-2xl p-8 flex items-start gap-5">
              <div class="w-11 h-11 rounded-xl bg-rose/20 flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b76e79" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="1" y="4" width="22" height="16" rx="2"/>
                  <line x1="1" y1="10" x2="23" y2="10"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-xl text-white mb-2 leading-snug">No Insurance? No Problem.</h3>
                <p class="font-body text-sm text-navy-lighter leading-relaxed">
                  We offer flexible third-party financing so your budget never stands between
                  you and the smile you deserve. Ask our team about payment plans today.
                </p>
              </div>
            </div>

          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 6 — FAQ
    ══════════════════════════════════════════════ -->
    <section class="bg-white py-24 md:py-32">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 xl:gap-24 items-start">

          <!-- Left: heading (sticky on desktop) -->
          <div class="lg:sticky lg:top-28">
            <div class="flex items-center gap-3 mb-5">
              <div class="h-px w-8 bg-rose shrink-0"></div>
              <span class="font-body text-rose-dark text-xs font-semibold tracking-[0.2em] uppercase">Common Questions</span>
            </div>
            <h2 class="font-heading text-5xl text-navy leading-snug mb-6">
              Common Questions<br />About Dental Implants.
            </h2>
            <p class="font-body text-md text-neutral leading-relaxed mb-10">
              Still have questions about the implant process? Here are the answers to what
              our patients ask most.
            </p>
            <CTAGroup />
          </div>

          <!-- Right: FAQ list -->
          <div class="flex flex-col gap-0 divide-y divide-cream-light">

            {[
              {
                q: 'Does the procedure hurt?',
                a: 'Most patients report that getting an implant is less uncomfortable than a standard extraction. We offer various sedation options to ensure you are completely relaxed throughout the procedure.',
              },
              {
                q: 'How long do implants last?',
                a: 'With proper care and regular checkups at our Fort Mill office, dental implants are designed to last a lifetime. They are one of the most durable and long-lasting tooth replacement options available.',
              },
              {
                q: 'Am I a candidate for implants?',
                a: 'Most adults with healthy gums and enough bone density are great candidates. We provide a thorough evaluation to determine the best path for you and will explain all your options before moving forward.',
              },
              {
                q: 'Do I need to see a specialist?',
                a: 'Not at Core Dentistry. Dr. Alexander and Dr. Burley provide comprehensive implant care in-house, from the initial consultation through the surgical phase and final restoration — all in one convenient Fort Mill location.',
              },
              {
                q: 'How is an implant different from a denture or bridge?',
                a: 'An implant replaces the tooth root itself, which preserves your jawbone and provides a stable, permanent foundation. Unlike dentures or bridges, implants do not rely on neighboring teeth or adhesives.',
              },
            ].map((item) => (
              <div class="py-7">
                <h3 class="font-heading text-xl text-navy mb-3 leading-snug">{item.q}</h3>
                <p class="font-body text-base text-neutral leading-relaxed">{item.a}</p>
              </div>
            ))}

          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 7 — CONTACT FORM
    ══════════════════════════════════════════════ -->
    <section id="request-appointment" class="bg-cream-lighter py-24 md:py-32">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 xl:gap-24 items-start">

          <!-- Left: copy + trust signals (sticky on desktop) -->
          <div class="lg:sticky lg:top-28">
            <div class="flex items-center gap-3 mb-5">
              <div class="h-px w-8 bg-rose shrink-0"></div>
              <span class="font-body text-rose-dark text-xs font-semibold tracking-[0.2em] uppercase">Schedule a Consultation</span>
            </div>
            <h2 class="font-heading text-5xl text-navy leading-snug mb-6">
              Schedule Your Implant<br />Consultation.
            </h2>
            <p class="font-body text-md text-neutral leading-relaxed mb-10">
              Ready to find out if dental implants are right for you? Fill out the form below
              or call our office to schedule a personalized consultation with our expert team.
            </p>

            <!-- Trust signal checklist -->
            <ul class="flex flex-col gap-4" role="list">
              {[
                'Comprehensive implant care under one roof',
                'Advanced 3D imaging for precision placement',
                'In-network with Delta Dental, Cigna, MetLife & more',
                'Flexible financing options available',
              ].map((item) => (
                <li class="flex items-center gap-3 font-body text-base text-navy">
                  <span class="w-5 h-5 rounded-full bg-rose flex items-center justify-center shrink-0" aria-hidden="true">
                    <svg width="10" height="8" viewBox="0 0 10 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <polyline points="1,4.5 3.5,7 9,1" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Right: form card -->
          <div class="bg-white rounded-3xl p-8 md:p-10 shadow-sm border border-cream-light">
            <h3 class="font-heading text-2xl text-navy mb-6 leading-snug">Submit Your Request</h3>
            <ContactForm />
          </div>

        </div>
      </div>
    </section>

</GlobalLayout>
