---
const phone = '(803) 471-4898';
const email = 'admin@coredentistrysc.com';
const addressLine1 = '485 Tom Hall St Suite 106';
const addressLine2 = 'Fort Mill, SC 29715';
const mapsHref = 'https://maps.app.goo.gl/jsrJMBriZoArMoLy9';

const telHref = `tel:${phone}`;
const mailHref = `mailto:${email}`;
---

<footer class="bg-navy-dark border-t border-navy">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 md:py-16">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10 md:gap-16">

      <!-- Logo -->
      <a href="/" class="shrink-0 no-underline self-start" aria-label="Core Dentistry – home">
        <img src="/images/Logo-new16bit.webp" alt="Core Dentistry" width="440" height="60" class="h-10 w-auto" />
      </a>

      <!-- Contact info -->
      <ul class="flex flex-col gap-5 font-body" role="list">

        <!-- Address -->
        <li class="flex items-start gap-3">
          <span class="mt-0.5 shrink-0 text-rose" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.07-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.003 3.5-4.697 3.5-8.327a8.79 8.79 0 10-17.58 0c0 3.63 1.555 6.324 3.5 8.327a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3.5 3.5 0 100-7 3.5 3.5 0 000 7z" />
            </svg>
          </span>
          <a
            href={mapsHref}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-white hover:text-rose transition-colors duration-200 no-underline"
            aria-label="Open in Google Maps"
          >
            <address class="not-italic">
              <span class="block">{addressLine1}</span>
              <span class="block">{addressLine2}</span>
            </address>
          </a>
        </li>

        <!-- Phone -->
        <li class="flex items-center gap-3">
          <span class="shrink-0 text-rose" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" />
            </svg>
          </span>
          <a
            href={telHref}
            class="text-sm font-medium text-white hover:text-rose transition-colors duration-200"
          >
            {phone}
          </a>
        </li>

        <!-- Email -->
        <li class="flex items-center gap-3">
          <span class="shrink-0 text-rose" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" />
              <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" />
            </svg>
          </span>
          <a
            href={mailHref}
            class="text-sm font-medium text-white hover:text-rose transition-colors duration-200"
          >
            {email}
          </a>
        </li>

      </ul>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-navy text-xs text-navy-lighter font-body">
      &copy; {new Date().getFullYear()} Core Dentistry. All rights reserved.
    </div>
  </div>
</footer>
