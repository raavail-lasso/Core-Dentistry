---
interface Props {
  variant?: 'default' | 'on-dark';
}

const { variant = 'default' } = Astro.props;
const phone = '(803) 471-4898';
const telHref = `tel:${phone}`;
const isOnDark = variant === 'on-dark';
---

<a
  href={telHref}
  class:list={[
    'inline-flex items-center gap-3 rounded-full px-6 py-3.5 font-body transition-colors duration-200 no-underline',
    isOnDark
      ? 'bg-white text-navy hover:bg-navy-lightest'
      : 'bg-navy text-white hover:bg-navy-dark',
  ]}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="currentColor"
    class="w-5 h-5 shrink-0"
    aria-hidden="true"
  >
    <path
      fill-rule="evenodd"
      d="M1.5 4.5a3 3 0 0 1 3-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 0 1-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 0 0 6.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 0 1 1.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 0 1-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z"
      clip-rule="evenodd"
    />
  </svg>
  <span class="flex flex-col leading-tight">
    <span class="text-xs font-medium tracking-widest uppercase opacity-70">Call Now</span>
    <span class="text-base font-semibold">{phone}</span>
  </span>
</a>
