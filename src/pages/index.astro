---
import GlobalLayout from '../layouts/GlobalLayout.astro';
import CTAGroup from '../components/CTAGroup.astro';
import ContactForm from '../components/ContactForm.astro';
---

<GlobalLayout description="Judgment-free dental care in Fort Mill & Tega Cay, SC. General, cosmetic, and restorative services led by Dr. Elizabeth Kovalenko. Request your visit today.">


    <!-- ══════════════════════════════════════════════
         SECTION 1 — HERO
    ══════════════════════════════════════════════ -->
    <section class="relative min-h-screen flex items-center overflow-hidden bg-navy-dark">

      <!-- Dot grid pattern -->
      <div
        class="absolute inset-0 opacity-[0.05]"
        style="background-image: radial-gradient(circle, #d0d3da 1px, transparent 1px); background-size: 32px 32px;"
        aria-hidden="true"
      ></div>

      <!-- Warm rose glow, bottom left -->
      <div
        class="absolute bottom-0 left-0 w-2/3 h-2/3 pointer-events-none"
        style="background: radial-gradient(ellipse at bottom left, rgba(183, 110, 121, 0.18) 0%, transparent 65%);"
        aria-hidden="true"
      ></div>

      <!-- Content -->
      <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20 items-center">

          <!-- Left: copy + CTAs -->
          <div>
            <!-- Eyebrow label -->
            <div class="flex items-center gap-3 mb-8">
              <div class="h-px w-10 bg-rose shrink-0"></div>
              <span class="font-body text-rose text-xs font-semibold tracking-[0.2em] uppercase">
                Serving Fort Mill &amp; Tega Cay
              </span>
            </div>

            <h1 class="font-heading text-7xl text-white leading-tight mb-8">
              Still Avoiding<br />
              the Dentist?<br />
              <em class="not-italic text-rose">No Lectures.</em><br />
              No Judgment.
            </h1>

            <!-- Divider accent -->
            <div class="w-16 h-px bg-rose mb-8"></div>

            <p class="font-body text-lg text-navy-lighter leading-relaxed mb-10 max-w-xl">
              It's easy to let months or even years slip by without a dental visit. Whether it's due
              to anxiety, a bad past experience, or just a busy schedule, we understand. At Core
              Dentistry, we aren't here to judge your history. We are here to protect your future.
            </p>

            <CTAGroup variant="on-dark" />
          </div>

          <!-- Right: placeholder image -->
          <div class="relative hidden lg:block">
            <div class="w-full aspect-4/5 rounded-3xl overflow-hidden">
              <img src="/images/General%20Dentistry.webp" alt="Core Dentistry Fort Mill dental office" class="w-full h-full object-cover" />
            </div>
            <!-- Floating trust badge -->
            <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl px-6 py-4 shadow-lg border border-cream-light">
              <p class="font-heading text-2xl text-navy leading-none mb-0.5">500+</p>
              <p class="font-body text-sm text-neutral">5-Star Reviews</p>
            </div>
          </div>

        </div>
      </div>

    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 2 — AGITATION
    ══════════════════════════════════════════════ -->
    <section class="bg-cream-lighter py-24 md:py-32">
      <div class="max-w-7xl mx-auto px-6 md:px-10">

        <!-- Section label + heading + body -->
        <div class="max-w-2xl mb-14">
          <div class="flex items-center gap-3 mb-5">
            <div class="h-px w-8 bg-rose shrink-0"></div>
            <span class="font-body text-rose-dark text-xs font-semibold tracking-[0.2em] uppercase">Why It Matters</span>
          </div>
          <h2 class="font-heading text-5xl text-navy leading-snug mb-5">
            A Small Ache Today Can<br />Become an Expensive<br />Emergency Tomorrow.
          </h2>
          <p class="font-body text-md text-neutral leading-relaxed">
            Dental issues do not heal on their own. What starts as minor sensitivity often evolves
            into a painful infection, a costly root canal, or even tooth loss. Waiting doesn't just
            make the treatment more complex — it makes it more expensive. Break the cycle of dental
            stress today before a small issue becomes a major problem.
          </p>
        </div>

        <!-- Three cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-14">

          <!-- Card 1: Dental Issues Don't Heal -->
          <div class="bg-white rounded-2xl p-8 border border-cream-light shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col gap-5">
            <div class="w-11 h-11 rounded-xl bg-rose-light flex items-center justify-center shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 22C12 22 4 16 4 9a8 8 0 0116 0c0 7-8 13-8 13z" stroke="#b76e79" stroke-width="1.75" stroke-linejoin="round"/>
                <circle cx="12" cy="9" r="2.5" stroke="#b76e79" stroke-width="1.75"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-heading text-2xl text-navy mb-2 leading-snug">Issues Don't Heal</h3>
              <p class="font-body text-base text-neutral leading-relaxed">
                Minor sensitivity left untreated escalates into infections, root canals, and
                eventually tooth loss — none of which go away on their own.
              </p>
            </div>
            <div class="pt-4 border-t border-cream-light">
              <p class="font-body text-sm text-rose-dark font-semibold">Delay always costs more</p>
            </div>
          </div>

          <!-- Card 2: Problems Compound -->
          <div class="bg-white rounded-2xl p-8 border border-cream-light shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col gap-5">
            <div class="w-11 h-11 rounded-xl bg-rose-light flex items-center justify-center shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="3,17 8,11 12,14 17,7" stroke="#b76e79" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="17,7 21,7 21,11" stroke="#b76e79" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="3" y1="20" x2="21" y2="20" stroke="#b76e79" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-heading text-2xl text-navy mb-2 leading-snug">Problems Compound</h3>
              <p class="font-body text-base text-neutral leading-relaxed">
                A small cavity becomes decay. Decay becomes a root canal. Root canals become
                extractions. Every step is more painful and more expensive.
              </p>
            </div>
            <div class="pt-4 border-t border-cream-light">
              <p class="font-body text-sm text-rose-dark font-semibold">Prevention is always simpler</p>
            </div>
          </div>

          <!-- Card 3: Emergencies Cost More -->
          <div class="bg-white rounded-2xl p-8 border border-cream-light shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col gap-5">
            <div class="w-11 h-11 rounded-xl bg-rose-light flex items-center justify-center shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="#b76e79" stroke-width="1.75" stroke-linejoin="round"/>
                <line x1="12" y1="9" x2="12" y2="13" stroke="#b76e79" stroke-width="1.75" stroke-linecap="round"/>
                <circle cx="12" cy="17" r="0.75" fill="#b76e79"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-heading text-2xl text-navy mb-2 leading-snug">Emergencies Cost More</h3>
              <p class="font-body text-base text-neutral leading-relaxed">
                Emergency dental treatment is far more expensive — and painful — than routine
                preventive visits. Don't wait for the crisis.
              </p>
            </div>
            <div class="pt-4 border-t border-cream-light">
              <p class="font-body text-sm text-rose-dark font-semibold">Act before the emergency</p>
            </div>
          </div>

        </div>

        <CTAGroup />

      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 3 — SOLUTION
    ══════════════════════════════════════════════ -->
    <section class="bg-white py-24 md:py-32 relative overflow-hidden">

      <!-- Decorative soft blush shape, right side -->
      <div
        class="absolute -right-48 top-1/2 -translate-y-1/2 w-[560px] h-[560px] rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(246, 238, 239, 0.85) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 xl:gap-24 items-center">

          <!-- Left: copy + CTAs -->
          <div>
            <div class="flex items-center gap-3 mb-5">
              <div class="h-px w-8 bg-rose shrink-0"></div>
              <span class="font-body text-rose-dark text-xs font-semibold tracking-[0.2em] uppercase">Our Approach</span>
            </div>
            <h2 class="font-heading text-5xl text-navy leading-snug mb-6">
              Compassionate Care<br />Under One Roof<br />in Fort Mill.
            </h2>
            <p class="font-body text-md text-neutral leading-relaxed mb-4">
              Led by Dr. Elizabeth Alexander and Dr. Erika Burley, Core Dentistry is designed to
              be your dental home. We've invested in advanced technology to make your visits faster,
              more accurate, and most importantly, pain-free.
            </p>
            <p class="font-heading text-2xl text-navy mb-6 leading-snug">
              "From gentle cleanings to<br />restorative care, we handle<br />it all under one roof."
            </p>
            <p class="font-body text-md text-neutral leading-relaxed mb-10">
              In a professional and personal environment, our team treats every patient like family
              — no matter how long it's been since your last visit.
            </p>
            <CTAGroup />
          </div>

          <!-- Right: feature highlight tiles -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

            <div class="flex items-start gap-4 p-6 bg-cream-lighter rounded-2xl border border-cream-light">
              <div class="w-10 h-10 rounded-xl bg-navy flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-xl text-navy mb-1 leading-snug">Gentle Cleanings</h3>
                <p class="font-body text-sm text-neutral leading-relaxed">Careful, comfortable care from our compassionate hygienists.</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-6 bg-cream-lighter rounded-2xl border border-cream-light">
              <div class="w-10 h-10 rounded-xl bg-navy flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="11" cy="11" r="7"/>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-xl text-navy mb-1 leading-snug">Advanced Technology</h3>
                <p class="font-body text-sm text-neutral leading-relaxed">High-tech diagnostics that catch issues before they become problems.</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-6 bg-cream-lighter rounded-2xl border border-cream-light">
              <div class="w-10 h-10 rounded-xl bg-navy flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-xl text-navy mb-1 leading-snug">Sedation Options</h3>
                <p class="font-body text-sm text-neutral leading-relaxed">Relax completely — we offer sedation so you never feel a thing.</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-6 bg-cream-lighter rounded-2xl border border-cream-light">
              <div class="w-10 h-10 rounded-xl bg-navy flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                  <path d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-xl text-navy mb-1 leading-snug">Judgment-Free Care</h3>
                <p class="font-body text-sm text-neutral leading-relaxed">No shame, no lectures. Just genuine care for you and your family.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 4 — TESTIMONIAL
    ══════════════════════════════════════════════ -->
    <section class="relative bg-navy py-24 md:py-32 overflow-hidden">

      <!-- Subtle dot grid -->
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 36px 36px;"
        aria-hidden="true"
      ></div>

      <!-- Decorative oversized opening quotation mark -->
      <div
        class="absolute -top-6 left-4 md:left-10 font-heading leading-none pointer-events-none select-none text-rose opacity-[0.08]"
        style="font-size: clamp(160px, 22vw, 300px);"
        aria-hidden="true"
      >"</div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-10 text-center">

        <div class="flex items-center gap-3 justify-center mb-8">
          <div class="h-px w-8 bg-rose shrink-0"></div>
          <span class="font-body text-rose text-xs font-semibold tracking-[0.2em] uppercase">Patient Stories</span>
          <div class="h-px w-8 bg-rose shrink-0"></div>
        </div>

        <h2 class="font-heading text-5xl text-white leading-snug mb-10">
          You Are in Safe Hands.
        </h2>

        <!-- Five stars -->
        <div class="flex items-center justify-center gap-1.5 mb-10" role="img" aria-label="Five-star patient review">
          {[1, 2, 3, 4, 5].map((_) => (
            <svg width="26" height="26" viewBox="0 0 24 24" fill="#f5c842" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>

        <blockquote class="font-heading text-3xl md:text-4xl text-white leading-snug mb-10 italic">
          "I have never felt more comfortable at a dentist. My mother had teeth in terrible shape
          and instead of being shamed, she was welcomed and able to get her dental care. I could
          not rave enough!"
        </blockquote>

        <div class="flex items-center justify-center gap-3">
          <div class="h-px w-8 bg-rose-dark shrink-0"></div>
          <cite class="font-body text-rose not-italic text-lg font-semibold">Lauren Still</cite>
          <div class="h-px w-8 bg-rose-dark shrink-0"></div>
        </div>

      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 5 — FINANCIALS
    ══════════════════════════════════════════════ -->
    <section class="bg-cream-lighter py-24 md:py-32">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 xl:gap-24 items-center">

          <!-- Left: copy -->
          <div>
            <div class="flex items-center gap-3 mb-5">
              <div class="h-px w-8 bg-rose shrink-0"></div>
              <span class="font-body text-rose-dark text-xs font-semibold tracking-[0.2em] uppercase">Insurance &amp; Payment</span>
            </div>
            <h2 class="font-heading text-5xl text-navy leading-snug mb-6">
              Transparent Pricing.<br />Easy Insurance.<br />No Surprises.
            </h2>
            <p class="font-body text-md text-neutral leading-relaxed mb-8">
              We believe quality dental care should be accessible to everyone in our community.
              We are In-Network with most major providers and our team will even file your claims
              and verify your benefits for you.
            </p>
            <p class="font-body text-md text-neutral leading-relaxed mb-10">
              No insurance? No problem. We offer flexible payment solutions and third-party
              financing options to ensure your budget never stands in the way of your health.
            </p>
            <CTAGroup />
          </div>

          <!-- Right: insurance providers + no-insurance callout -->
          <div class="flex flex-col gap-6">

            <!-- In-Network card -->
            <div class="bg-white rounded-2xl p-8 border border-cream-light shadow-sm">
              <h3 class="font-heading text-xl text-navy mb-5 leading-snug">We're In-Network With</h3>
              <ul class="grid grid-cols-2 gap-3">
                {['Aetna', 'Cigna', 'Delta Dental', 'MetLife', 'UnitedHealthcare', 'And more…'].map((name) => (
                  <li class="flex items-center gap-2.5 font-body text-base text-navy">
                    <span class="w-5 h-5 rounded-full bg-rose flex items-center justify-center shrink-0" aria-hidden="true">
                      <svg width="10" height="8" viewBox="0 0 10 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <polyline points="1,4.5 3.5,7 9,1" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    {name}
                  </li>
                ))}
              </ul>
            </div>

            <!-- No insurance callout -->
            <div class="bg-navy rounded-2xl p-8 flex items-start gap-5">
              <div class="w-11 h-11 rounded-xl bg-rose/20 flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b76e79" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="1" y="4" width="22" height="16" rx="2"/>
                  <line x1="1" y1="10" x2="23" y2="10"/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-xl text-white mb-2 leading-snug">No Insurance? No Problem.</h3>
                <p class="font-body text-sm text-navy-lighter leading-relaxed">
                  We offer flexible financing options so your budget never stands between you and
                  the care you deserve. Ask our team about payment plans.
                </p>
              </div>
            </div>

          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 6 — FAQ
    ══════════════════════════════════════════════ -->
    <section class="bg-white py-24 md:py-32">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 xl:gap-24 items-start">

          <!-- Left: heading -->
          <div class="lg:sticky lg:top-28">
            <div class="flex items-center gap-3 mb-5">
              <div class="h-px w-8 bg-rose shrink-0"></div>
              <span class="font-body text-rose-dark text-xs font-semibold tracking-[0.2em] uppercase">New Patients</span>
            </div>
            <h2 class="font-heading text-5xl text-navy leading-snug mb-6">
              Common Questions<br />from New Patients.
            </h2>
            <p class="font-body text-md text-neutral leading-relaxed mb-10">
              We know the first step is often the hardest. These are the questions we hear most
              from patients who haven't visited a dentist in a while.
            </p>
            <CTAGroup />
          </div>

          <!-- Right: FAQ list -->
          <div class="flex flex-col gap-0 divide-y divide-cream-light">

            {[
              {
                q: 'It\'s been years since my last visit. Will I be lectured?',
                a: 'Absolutely not. We are just happy you\'ve chosen us to help you get back on track. Our entire practice is built around judgment-free care — no shame, no scolding, ever.',
              },
              {
                q: 'Do you see children?',
                a: 'Yes! We are a family practice. We even put on SpongeBob to help the little ones feel at home. Kids of all ages are welcome.',
              },
              {
                q: 'What if I have a dental emergency?',
                a: 'Call us immediately. We strive to offer same-day or next-day appointments for urgent needs. Don\'t wait — call our office right away.',
              },
              {
                q: 'Do you offer sedation for anxious patients?',
                a: 'Yes. We offer several sedation options to help patients who experience dental anxiety feel completely comfortable and relaxed throughout their visit.',
              },
              {
                q: 'How quickly can I get an appointment?',
                a: 'We do our best to accommodate new patients quickly. Fill out the form below and our team will reach out within 24 hours to find a time that works for your schedule.',
              },
            ].map((item) => (
              <div class="py-7">
                <h3 class="font-heading text-xl text-navy mb-3 leading-snug">{item.q}</h3>
                <p class="font-body text-base text-neutral leading-relaxed">{item.a}</p>
              </div>
            ))}

          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         SECTION 7 — CONTACT FORM
    ══════════════════════════════════════════════ -->
    <section id="request-appointment" class="bg-cream-lighter py-24 md:py-32">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 xl:gap-24 items-start">

          <!-- Left: copy + trust signals (sticky on desktop) -->
          <div class="lg:sticky lg:top-28">
            <div class="flex items-center gap-3 mb-5">
              <div class="h-px w-8 bg-rose shrink-0"></div>
              <span class="font-body text-rose-dark text-xs font-semibold tracking-[0.2em] uppercase">Book Your Visit</span>
            </div>
            <h2 class="font-heading text-5xl text-navy leading-snug mb-6">
              Ready to Smile Again?<br />Request Your Visit.
            </h2>
            <p class="font-body text-md text-neutral leading-relaxed mb-10">
              Fill out the form and a member of our Fort Mill team will reach out shortly to find
              a time that works for you.
            </p>

            <!-- Trust signal checklist -->
            <ul class="flex flex-col gap-4" role="list">
              {[
                'No judgment — ever',
                'We verify your insurance for you',
                'Response within 24 hours',
                'Serving Fort Mill & Tega Cay families',
              ].map((item) => (
                <li class="flex items-center gap-3 font-body text-base text-navy">
                  <span class="w-5 h-5 rounded-full bg-rose flex items-center justify-center shrink-0" aria-hidden="true">
                    <svg width="10" height="8" viewBox="0 0 10 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <polyline points="1,4.5 3.5,7 9,1" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Right: form card -->
